# ============================================================================
# Mongodb Data Research Agent - Environment Variables Template
# ============================================================================
# Copy this file to .env and fill in your actual values
# Then run: source .env OR use python-dotenv to load automatically

# ============================================================================
# REQUIRED: Slack Configuration
# ============================================================================
# Get these from: https://api.slack.com/apps
SLACK_BOT_TOKEN=xoxb-your-bot-user-oauth-token-here
SLACK_APP_TOKEN=xapp-your-app-level-token-here

# ============================================================================
# REQUIRED: MongoDB Atlas Connection
# ============================================================================
# Get this from: MongoDB Atlas Console > Connect > Drivers
MDB_MCP_CONNECTION_STRING=mongodb+srv://username:password@cluster.mongodb.net/?retryWrites=true&w=majority

# ============================================================================
# OPTIONAL: Atlas Admin API (for billing, alerts, performance advisor)
# ============================================================================
# Get these from: https://cloud.mongodb.com/v2#/account/publicApi
# MDB_MCP_API_CLIENT_ID=your-public-api-key
# MDB_MCP_API_CLIENT_SECRET=your-private-api-key

# ============================================================================
# OPTIONAL: AWS Configuration
# ============================================================================
# If not running on EC2 with IAM role, configure AWS credentials here
# AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=your-access-key
# AWS_SECRET_ACCESS_KEY=your-secret-key

# ============================================================================
# OPTIONAL: Timeout Configuration (adjust if needed)
# ============================================================================
# MCP_INIT_TIMEOUT=30          # MCP session initialization timeout (seconds)
# TOOL_LOAD_TIMEOUT=60         # Tool loading timeout (seconds)
# AGENT_TIMEOUT=300            # Agent execution timeout (seconds)
